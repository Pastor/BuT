// Корректный доступ к битам переменных.
//
// Все обращения к битам находятся в пределах ширины типа.

model TestBitAccess {
    // Переменные разных битовых типов
    let mut byte_val: [8:   bit] = 0;   // 8 бит: биты 0..7
    let mut word_val: [16:  bit] = 0;   // 16 бит: биты 0..15
    let mut dword_val: [32: bit] = 0;   // 32 бита: биты 0..31

    state Active {
        // Корректные обращения: индекс < ширина типа
        enter -> {
            byte_val.0 = true;   // бит 0 из 8 — ОК
            byte_val.7 = true;   // бит 7 из 8 — ОК (последний)
            word_val.15 = true;  // бит 15 из 16 — ОК
            dword_val.31 = true; // бит 31 из 32 — ОК
        }
        ref Active : byte_val.0;   // чтение бита в условии — ОК
    }

    start -> Active;
}
