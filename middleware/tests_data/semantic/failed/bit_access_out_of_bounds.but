// Семантическая ошибка: обращение к биту за пределами типа.
//
// Тип [8: bit] имеет ширину 8 бит (биты 0..7).
// Обращение к биту 8 или больше — ошибка выхода за границы.

model TestOutOfBounds {
    let mut a: [8: bit] = 0;

    state Check {
        // Ошибка: бит 8 выходит за границы типа [8: bit] (0..7)
        enter -> { a.8 = true; }
    }

    start -> Check;
}
