// Основной файл приложения.
// Импортирует библиотечные типы из внешних директорий,
// которые НЕ находятся рядом с этим файлом.
//
// Для разрешения импортов необходимо передать дополнительные
// пути поиска через add_search_path() или --include-dir.

import "shared/defs";
import "hardware/regs";

model Application {
    start -> Idle;
    state Idle { ref Idle; }
}
