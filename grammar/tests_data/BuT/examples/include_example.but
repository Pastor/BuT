// Пример использования механизма include (import) языка BuT.
// Файл: include_example.but
//
// Демонстрирует:
//   1. Прямой импорт файла с типами
//   2. Использование импортированных типов в модели
//   3. Цепочку включений (include chain)
//
// Для компиляции этого файла необходим include_shared_types.but в той же директории.

// ── Импорт разделяемых типов ──────────────────────────────────────────────────

import "include_shared_types";

// ── Константы протокола ───────────────────────────────────────────────────────

/// Максимальное число попыток отправки пакета
const MAX_RETRIES: int = 3;

// ── Модель канального контроллера ────────────────────────────────────────────

/// Контроллер канала передачи данных с поддержкой повторных попыток.
/// Использует типы Flag, Byte и Address из include_shared_types.but.
model ChannelController {
    // ── Переменные ─────────────────────────────────────────────────────────────
    let mut retries: int = 0;     // Счётчик попыток
    let mut ack: bit = 0;         // Флаг подтверждения
    let mut err: bit = 0;         // Флаг ошибки

    // ── Состояния ────────────────────────────────────────────────────────────

    /// Ожидание запроса на передачу
    state Idle {
        ref Sending: port_req;
    }

    /// Передача пакета
    state Sending {
        ref WaitAck;
        enter -> retries = 0;
    }

    /// Ожидание подтверждения
    state WaitAck {
        ref Done:  ack;
        ref Retry: err & retries < MAX_RETRIES;
        ref Error: err & retries >= MAX_RETRIES;
    }

    /// Повторная попытка после ошибки
    state Retry {
        ref Sending;
        enter -> retries = retries + 1;
    }

    /// Успешное завершение
    state Done {
        ref Idle;
    }

    /// Ошибка — исчерпаны попытки
    state Error {
        ref Idle;
    }

    // ── Начальное состояние ───────────────────────────────────────────────────
    start -> Idle;
}

// ── Порты ввода-вывода ────────────────────────────────────────────────────────

port port_req: bit = 1;
