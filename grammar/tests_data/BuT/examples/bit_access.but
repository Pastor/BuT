// Пример: доступ к конкретному биту переменной в BuT.
//
// Операция `переменная.N` обеспечивает чтение и запись N-го бита
// (нумерация с 0, начиная с младшего бита).
//
// Синтаксис:
//   expr.N       — чтение N-го бита (возвращает 0 или 1)
//   var.N = expr — запись значения в N-й бит переменной
//
// Генерация кода:
//   C:       ((var) >> N) & 1              — чтение
//            var = ((var) & ~(1UL << N)) | ((expr & 1) << N)  — запись
//   Verilog: var[N]                        — чтение и запись
//
// Семантический анализ проверяет, что N < ширина_типа.
// Например, для типа [8: bit] допустимы только биты 0..7.
//
// Подключаем стандартную библиотеку типов
import "include/std";

// ── Глобальные переменные состояния ───────────────────────────────────────────

/// Регистр флагов устройства (8 бит)
port flags_reg : [8: bit] = 0x00;

/// Статусный регистр (16 бит)
port status_reg : [16: bit] = 0x0000;

/// Маска прерываний (32 бита)
port irq_mask : [32: bit] = 0x00000000;

// ── Модель: контроллер флагов устройства ──────────────────────────────────────

/// Конечный автомат управления флагами устройства.
/// Демонстрирует чтение и запись отдельных битов.
model FlagsController {
    // Переменная для хранения промежуточного результата
    let mut temp: [8: bit] = 0;

    // ── Состояния ─────────────────────────────────────────────────────────────

    /// Ожидание — флаг READY (бит 0) ещё не установлен
    state Idle {
        // Переход в Ready когда бит 0 флагового регистра установлен
        ref Ready : flags_reg.0;
        ref Idle  : !flags_reg.0;
        enter -> {
            // Сброс бита ERROR (бит 7)
            flags_reg.7 = false;
            // Сброс бита BUSY (бит 1)
            flags_reg.1 = false;
        }
    }

    /// Устройство готово к работе — READY = 1
    state Ready {
        // Переход в Processing если бит START (бит 2) установлен
        ref Processing : flags_reg.2;
        ref Idle       : !flags_reg.0;
        enter -> {
            // Установить бит READY (бит 0) в статусном регистре
            status_reg.0 = true;
        }
    }

    /// Обработка данных — BUSY = 1
    state Processing {
        // Проверяем бит DONE (бит 4) флагового регистра
        ref Done  : flags_reg.4;
        ref Error : flags_reg.7;
        enter -> {
            // Установить бит BUSY (бит 1)
            flags_reg.1 = true;
            // Сбросить бит START (бит 2)
            flags_reg.2 = false;
            // Включить прерывание 0 в маске (бит 0)
            irq_mask.0 = true;
        }
    }

    /// Завершение обработки
    state Done {
        ref Idle;
        enter -> {
            // Сбросить BUSY (бит 1), установить DONE (бит 4)
            flags_reg.1 = false;
            flags_reg.4 = false;
            // Сохранить биты 0..3 как результат в temp
            temp.0 = flags_reg.0;
            temp.1 = flags_reg.1;
            temp.2 = flags_reg.2;
            temp.3 = flags_reg.3;
        }
    }

    /// Ошибка — ERROR = 1
    state Error {
        ref Idle : !flags_reg.7;
        enter -> {
            // Бит ERROR (бит 7) уже установлен, сбрасываем BUSY
            flags_reg.1 = false;
            // Отключаем прерывание 0
            irq_mask.0 = false;
        }
    }

    start -> Idle;
}
