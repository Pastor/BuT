// Аппаратно-зависимые типы платформы.
// Находятся в libs/platform/ — отдельной библиотеке HAL.

/// Регистр управления периферийным устройством
type ControlReg  = [16: bit];

/// Регистр статуса периферийного устройства
type StatusReg   = [8:  bit];

/// Адрес памяти (32-разрядная платформа)
type MemAddress  = [32: bit];

/// Маска прерываний
type IrqMask     = [32: bit];
