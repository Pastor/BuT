// Пример: использование стандартной библиотеки типов (std.but) в BuT.
//
// Демонстрирует:
//   1. Подключение std.but через import
//   2. Использование производных типов (u8, u16, u32, u64, u128, bool)
//   3. Генерацию C-кода: u8 → uint8_t, u32 → uint32_t, u128 → uint64_t[2]
//   4. Генерацию ST-кода: u8 → BYTE, u32 → DWORD, u128 → ARRAY [0..1] OF LWORD
//   5. Использование float как базового математического типа
//
// В языке BuT существуют только два базовых (примитивных) типа:
//   bit   — 1 логический бит
//   float — число с плавающей точкой
//
// Все остальные типы выводятся из bit через конструкцию [N: bit].
// Файл include/std.but содержит стандартные определения таких типов.

import "include/std";

// ── Глобальные константы ──────────────────────────────────────────────────────

/// Максимальное число шагов датчика
const MAX_STEPS: u32 = 1000;

/// Пороговое значение температуры (плавающая точка)
const TEMP_THRESHOLD: float = 75.5;

// ── Глобальные порты ──────────────────────────────────────────────────────────

/// Входной сигнал датчика (1 байт = 8 бит)
port sensor_in  : u8    = 0x00;

/// Флаг тревоги (1 бит)
port alarm_out  : Flag  = false;

/// Счётчик тактов (32 бита)
port tick_count : Counter = 0;

/// Уникальный идентификатор устройства (128 бит)
port device_id  : u128  = 0;

// ── Модель: контроллер температурного датчика ─────────────────────────────────

/// Конечный автомат мониторинга температурного датчика.
/// Использует типы из std.but: u8, Flag, Counter, u128, float.
model TempSensor {
    // Переменные модели
    let mut steps : Counter = 0;    // Счётчик шагов (u32)
    let mut ready : Flag    = false; // Флаг готовности (bool/bit)

    // ── Состояния ─────────────────────────────────────────────────────────────

    /// Ожидание активации датчика
    state Idle {
        ref Active : sensor_in > 0;
        enter -> {
            steps = 0;
            ready = false;
            alarm_out = false;
        }
    }

    /// Датчик активен, накопление данных
    state Active {
        ref Alarm  : sensor_in >= 200;
        ref Done   : steps >= MAX_STEPS;
        ref Active : sensor_in > 0;
        ref Idle   : sensor_in = 0;
        enter -> {
            steps += 1;
            tick_count += 1;
        }
    }

    /// Состояние тревоги (превышен порог)
    state Alarm {
        ref Idle : alarm_out = false;
        enter -> {
            alarm_out = true;
            steps = 0;
        }
    }

    /// Завершение цикла измерения
    state Done {
        ref Idle;
        enter -> {
            ready = true;
        }
    }

    start -> Idle;
}
