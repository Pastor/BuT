// Разделяемые типы для примера include-механизма.
// Файл: include_shared_types.but
//
// Определяет базовые типы данных, используемые в нескольких моделях проекта.
// Импортируется через: import "include_shared_types";

/// Однобитовый флаг
type Flag = bit;

/// Байт данных (8 бит)
type Byte = [8: bit];

/// Физический адрес устройства (16 бит)
type Address = [16: bit];
