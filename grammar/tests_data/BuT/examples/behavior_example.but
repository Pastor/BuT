/// Example of model composition and end-of-composition handling.
///
/// Demonstrates:
///   - Sequential composition: M1 + M2 + M3
///   - Parallel composition:   M1 | M2 | M3
///   - Choice (single model):  M = A
///   - The `end` property — action executed after a model or composition finishes

// ── Base models ──────────────────────────────────────────────────────────────

/// First processing stage
model Calibrate {
    start Running {
        ref Done : samples_ready;
    }
    state Done { }

    /// Action on calibration completion
    end -> { calibration_done = 1; }
}

/// Second processing stage
model Process {
    start Idle {
        ref Active : start_signal;
    }
    state Active {
        enter -> { status = 1; }
        ref Done  : result_ready;
        ref Idle  : !start_signal;
    }
    state Done {
        enter -> { status = 2; }
    }

    /// Signal completion after finishing
    end -> { process_done = 1; }
}

/// Final result storage stage
model Store {
    start Writing {
        ref Complete : write_done;
    }
    state Complete { }

    end -> { stored = 1; }
}

// ── Sequential composition ───────────────────────────────────────────────────

/// Pipeline: runs Calibrate → Process → Store sequentially.
/// Each model starts only after the previous one finishes.
/// Syntax: model Name = M1 + M2 + M3 { ... }
model Pipeline = Calibrate + Process + Store {
    /// Executed after all three stages have completed
    end -> { pipeline_complete = 1; }
}

// ── Parallel composition ──────────────────────────────────────────────────────

/// Runs Calibrate and Process in parallel, waits for both to finish.
/// Syntax: model Name = M1 | M2 { ... }
model ParallelPrep = Calibrate | Process {
    end -> { prep_done = 1; }
}

// ── Three models in parallel ──────────────────────────────────────────────────

/// All three models run simultaneously.
model FullParallel = Calibrate | Process | Store {
    end -> { all_done = 1; }
}

// ── Choice (single sub-model) ─────────────────────────────────────────────────

/// Delegates to a single concrete model.
/// Syntax: model Name = M { ... }
model RunCalibrate = Calibrate {
    end -> { choice_done = 1; }
}

model Composite = ((Calibrate | Process) + Store) | Calibrate {}

// ── Global ports ──────────────────────────────────────────────────────────────

port samples_ready    : bit = 0;
port start_signal     : bit = 0;
port result_ready     : bit = 0;
port write_done       : bit = 0;
port status           : bit = 0;
port calibration_done : bit = 0;
port process_done     : bit = 0;
port stored           : bit = 0;
port pipeline_complete: bit = 0;
port prep_done        : bit = 0;
port all_done         : bit = 0;
port choice_done      : bit = 0;
